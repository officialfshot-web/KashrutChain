{
  "manifest_version": 3,
  "name": "ShelfLife — Pantry & Recipe Assistant",
  "version": "1.0.0",
  "description": "Track your fridge and pantry items, get expiry alerts, and discover recipes based on what you have.",
  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ShelfLife"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
